# --- AI Models ---
# The default Gemini model to use (e.g., gemini-2.5-flash)
DEFAULT_MODEL=gemini-2.5-flash
GOOGLE_API_KEY=your_gemini_api_key

# --- Google OAuth Credentials ---
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret

# --- Security ---
# Secret key for token encryption (use a strong random string)
SECRET_KEY=your_strong_secret_key_here
SECRET_KEY_SALT=your_random_salt_string_here

# Required for Webhook & Cloud Task OIDC Audience validation. 
# Defaults to BASE_PROJECT_URL if not set.
OIDC_AUDIENCE=your_project_url_or_client_id
# The base deployment URL of this backend (used for webhooks and auth redirects)
BASE_PROJECT_URL=https://your-backend-url.com

# --- Supabase ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_role_key
# Connection string for AsyncPostgresSaver (e.g., postgresql://user:password@host:port/dbname)
SUPABASE_DB_URL=postgresql://postgres:your_db_password@db.your-project-id.supabase.co:5432/postgres
#
SUPABASE_USER_FILE_BUCKET=your_storage_bucket_name

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=your_redis_password

# --- Web Server ---
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173,http://localhost:8000
LOG_LEVEL=INFO

# --- Gmail Auto-Reply & Notifications ---
# Set these if using Google Cloud Pub/Sub for Gmail push notifications
PUBSUB_TOPIC=projects/your-project/topics/your-topic
# Custom token to map incoming Pub/Sub requests (must match the push endpoint query param)
PUBSUB_WEBHOOK_TOKEN=your_secure_webhook_token_here
AUTO_REPLY_HOURLY_LIMIT=20

CLOUD_TASKS_PROJECT=your-gcp-project-id
CLOUD_TASKS_LOCATION=us-central1
CLOUD_TASKS_QUEUE_NAME=koba-agents-queue
CLOUD_TASKS_SERVICE_ACCOUNT_EMAIL=your-service-account@your-gcp-project-id.iam.gserviceaccount.com
# Custom token for internal validation between your webhook and cloud task processor
CLOUD_TASKS_TOKEN=your_secure_internal_tasks_token_here
